# LLM
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
USE_MOCK_LLM=true

# Auth
JWT_SECRET=change-this-in-production
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_DISCOVERY_URL=
SSO_REDIRECT_URI=http://localhost:8000/auth/sso/callback

# Langfuse (create project at http://localhost:3000 after docker-compose up)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# Phoenix
PHOENIX_OTLP_ENDPOINT=http://localhost:4317
PHOENIX_UI_URL=http://localhost:6006

# Services
QDRANT_HOST=localhost
ELASTICSEARCH_URL=http://localhost:9200
